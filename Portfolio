    <style>
        :root {
            /* Premium High-Contrast Developer Palette */
            --bg-base: #060913;
            --bg-surface: #0f1526;
            --bg-card: rgba(20, 30, 54, 0.65);
            --color-primary: #38bdf8;   /* Electric Sky Blue */
            --color-secondary: #34d399; /* Mint Emerald */
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-glow: rgba(56, 189, 248, 0.15);
            --border-glass: rgba(255, 255, 255, 0.06);
            --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--color-primary); }

        /* Global Layout Components */
        .container {
            max-width: 1250px;
            margin: 0 auto;
            padding: 0 2.5rem;
        }

        section {
            padding: 7.5rem 0 3.5rem 0;
            position: relative;
        }

        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            transition: var(--transition-smooth);
        }

        .section-header {
            margin-bottom: 4rem;
        }

        .section-tag {
            color: var(--color-primary);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            display: block;
            margin-bottom: 0.5rem;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        /* Navigation Bar */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 1.25rem 0;
            background: rgba(6, 9, 19, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-glass);
            transition: var(--transition-smooth);
        }

        nav .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-weight: 800;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
            text-decoration: none;
            color: #fff;
        }

        .logo span { color: var(--color-primary); }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.5rem;
            align-items: center;
        }

        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: var(--transition-smooth);
        }

        .nav-links a:hover, .nav-links a.active {
            color: var(--color-primary);
        }

        /* Hero Architecture */
        #hero {
            min-height: 95vh;
            display: flex;
            align-items: center;
            background: radial-gradient(circle at 85% 30%, rgba(56, 189, 248, 0.07) 0%, transparent 60%);
            padding-top: 4rem;
        }

        .hero-layout {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .hero-headline {
            font-size: 3.8rem;
            line-height: 1.15;
            font-weight: 900;
            letter-spacing: -1.5px;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #fff 40%, var(--text-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-sub {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin-bottom: 3rem;
            max-width: 640px;
        }

        .btn-group {
            display: flex;
            gap: 1.25rem;
            flex-wrap: wrap;
        }

        .btn {
            padding: 0.9rem 2rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.95rem;
            transition: var(--transition-smooth);
            cursor: pointer;
        }

        .btn-primary {
            background: var(--color-primary);
            color: var(--bg-base);
            border: 1px solid var(--color-primary);
        }

        .btn-primary:hover {
            background: transparent;
            color: var(--color-primary);
            box-shadow: 0 0 25px rgba(56, 189, 248, 0.35);
        }

        .btn-secondary {
            background: transparent;
            color: var(--text-primary);
            border: 1px solid var(--border-glass);
        }

        .btn-secondary:hover {
            border-color: var(--text-secondary);
            background: rgba(255, 255, 255, 0.02);
        }

        /* Avatar Display Container */
        .hero-media {
            display: flex;
            justify-content: center;
            position: relative;
        }

        .avatar-frame {
            width: 340px;
            height: 340px;
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
            background: linear-gradient(45deg, var(--color-primary), var(--color-secondary));
            padding: 4px;
            animation: morphing 8s ease-in-out infinite alternate;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .avatar-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: inherit;
            background: var(--bg-surface);
        }

        @keyframes morphing {
            0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
            100% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; }
        }

        /* Summary & Achievements Overview */
        .summary-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 4rem;
        }

        .summary-text p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
        }

        .metrics-block {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        .metric-item {
            padding: 2rem 1.5rem;
            text-align: center;
        }

        .metric-num {
            font-size: 2.8rem;
            font-weight: 800;
            color: var(--color-secondary);
            display: block;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .metric-title {
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        /* Interactive Tech Stack Grid */
        .filter-shelf {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 2.5rem;
            flex-wrap: wrap;
        }

        .shelf-btn {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-glass);
            color: var(--text-secondary);
            padding: 0.6rem 1.4rem;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.85rem;
            transition: var(--transition-smooth);
        }

        .shelf-btn.active, .shelf-btn:hover {
            background: rgba(56, 189, 248, 0.1);
            border-color: var(--color-primary);
            color: var(--color-primary);
        }

        .stack-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1.25rem;
        }

        .stack-item {
            padding: 1.25rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 600;
        }

        .stack-item i {
            font-size: 1.4rem;
            color: var(--color-primary);
        }

        /* Experience Timeline Design */
        .timeline-container {
            max-width: 900px;
            margin: 0 auto;
            position: relative;
        }

        .timeline-container::before {
            content: '';
            position: absolute;
            left: 20px;
            top: 10px;
            bottom: 10px;
            width: 2px;
            background: linear-gradient(to bottom, var(--color-primary), var(--bg-base));
        }

        .timeline-card {
            position: relative;
            padding-left: 4.5rem;
            margin-bottom: 4rem;
        }

        .timeline-node {
            position: absolute;
            left: 11px;
            top: 4px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--bg-base);
            border: 4px solid var(--color-primary);
            z-index: 2;
        }

        .time-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid rgba(56, 189, 248, 0.2);
            color: var(--color-primary);
            font-size: 0.8rem;
            font-weight: 700;
            border-radius: 4px;
            margin-bottom: 0.75rem;
            text-transform: uppercase;
        }

        .job-title { font-size: 1.5rem; font-weight: 700; }
        .company-label { color: var(--text-secondary); display: block; margin-bottom: 1.25rem; font-weight: 500; }
        
        .bullet-list { padding-left: 1.25rem; color: var(--text-secondary); }
        .bullet-list li { margin-bottom: 0.6rem; }

        /* Advanced Project Card Architecture */
        .project-masonry {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
            gap: 2.5rem;
        }

        .showcase-card {
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .showcase-card:hover {
            transform: translateY(-6px);
            border-color: rgba(56, 189, 248, 0.25);
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.5);
        }

        .image-wrapper {
            width: 100%;
            height: 210px;
            position: relative;
            overflow: hidden;
            background: #1e293b;
            border-bottom: 1px solid var(--border-glass);
        }

        .image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-smooth);
        }

        .showcase-card:hover .image-wrapper img {
            transform: scale(1.05);
        }

        /* Mock UI screen helper inside card */
        .mock-ui-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #111c36 0%, #090e1a 100%);
            color: rgba(255,255,255,0.15);
            font-size: 3.5rem;
        }

        .card-body {
            padding: 2rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-meta {
            color: var(--color-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .card-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; }
        .card-desc { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1.75rem; flex-grow: 1; }

        .tag-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .tag-chip {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-glass);
            padding: 0.3rem 0.8rem;
            font-size: 0.8rem;
            border-radius: 4px;
            color: var(--text-secondary);
        }

        /* Credentials Grid */
        .certifications-shelf {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .cert-badge-card {
            padding: 1.75rem;
            display: flex;
            align-items: flex-start;
            gap: 1.25rem;
        }

        .cert-badge-card i {
            font-size: 2rem;
            color: var(--color-secondary);
        }

        .cert-info h4 { font-size: 1.1rem; margin-bottom: 0.25rem; }
        .cert-info p { color: var(--text-secondary); font-size: 0.85rem; }

        /* Integrated Education Info */
        .education-wrapper {
            max-width: 800px;
            margin: 0 auto;
            padding: 2.5rem;
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .edu-icon-box {
            width: 70px;
            height: 70px;
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid rgba(56, 189, 248, 0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--color-primary);
        }

        /* Unified Footer Connection Hub */
        #connect {
            padding-bottom: 6rem;
            background: linear-gradient(to top, rgba(15, 21, 38, 0.4) 0%, transparent 100%);
        }

        .dock-layout {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 4rem;
        }

        .social-dock {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
            margin-top: 1.5rem;
        }

        .dock-link {
            padding: 1.5rem 1rem;
            text-align: center;
            text-decoration: none;
            color: var(--text-primary);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .dock-link i { font-size: 1.8rem; transition: var(--transition-smooth); }
        .dock-link.li-link i { color: #0077b5; }
        .dock-link.gh-link i { color: #fff; }
        .dock-link.ig-link i { color: #e1306c; }

        .dock-link:hover {
            border-color: var(--color-primary);
            transform: translateY(-4px);
        }

        .msg-form {
            padding: 2.5rem;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        .input-box {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .input-box.wide { grid-column: span 2; }
        .input-box label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; font-weight: 700; }
        
        .input-box input, .input-box textarea {
            background: rgba(6, 9, 19, 0.5);
            border: 1px solid var(--border-glass);
            padding: 0.85rem;
            border-radius: 6px;
            color: #fff;
            font-size: 0.95rem;
            outline: none;
            transition: var(--transition-smooth);
        }

        .input-box input:focus, .input-box textarea:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 12px rgba(56, 189, 248, 0.1);
        }

        footer {
            text-align: center;
            padding: 2.5rem 0;
            border-top: 1px solid var(--border-glass);
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Layout Adjustments for Tablet/Mobile viewports */
        @media (max-width: 968px) {
            .hero-layout, .summary-grid, .dock-layout {
                grid-template-columns: 1fr;
                gap: 3.5rem;
            }
            .hero-headline { font-size: 2.8rem; }
            .hero-layout { text-align: center; }
            .hero-sub, .btn-group { margin-left: auto; margin-right: auto; justify-content: center; }
            .nav-links { display: none; } /* Kept clean for high scannability */
        }
    </style>
</head>
