        const structuralTechStack = [
            { name: 'C# Programming', icon: 'fa-code', type: 'backend' },
            { name: '.NET Core Engine', icon: 'fa-gears', type: 'backend' },
            { name: 'ASP.NET Architecture', icon: 'fa-network-wired', type: 'backend' },
            { name: 'Entity Framework Core', icon: 'fa-database', type: 'backend' },
            { name: 'REST Architecture', icon: 'fa-link', type: 'backend' },
            { name: 'Blazor UI Layouts', icon: 'fa-cubes', type: 'frontend' },
            { name: 'Radzen Componentry', icon: 'fa-border-top-left', type: 'frontend' },
            { name: 'JavaScript Core', icon: 'fa-brands fa-js', type: 'frontend' },
            { name: 'HTML5 & CSS Systems', icon: 'fa-brands fa-html5', type: 'frontend' },
            { name: 'SQL Server (SSMS)', icon: 'fa-server', type: 'db' },
            { name: 'T-SQL Logic Engines', icon: 'fa-terminal', type: 'db' },
            { name: 'Performance Indexing', icon: 'fa-bolt', type: 'db' },
            { name: 'Git & Source Control', icon: 'fa-brands fa-git-alt', type: 'backend' },
            { name: 'Power BI Reporting', icon: 'fa-chart-simple', type: 'db' }
        ];

        function populateStack(items) {
            const displayShelf = document.getElementById('tech-stack-shelf');
            displayShelf.innerHTML = '';
            items.forEach(tech => {
                const element = document.createElement('div');
                element.className = 'stack-item glass-card';
                element.innerHTML = `<i class="fa-solid ${tech.icon}"></i> <span>${tech.name}</span>`;
                displayShelf.appendChild(element);
            });
        }

        function filterTech(type) {
            const buttons = document.querySelectorAll('.shelf-btn');
            buttons.forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');

            if (type === 'all') {
                populateStack(structuralTechStack);
            } else {
                const isolation = structuralTechStack.filter(item => item.type === type);
                populateStack(isolation);
            }
        }

        // Keep Top Nav Highlight Actions tracking scrolling changes
        window.addEventListener('scroll', () => {
            let activeId = '';
            const zones = document.querySelectorAll('section');
            const targetLinks = document.querySelectorAll('.nav-links a');
            
            zones.forEach(zone => {
                const targetPoint = zone.offsetTop;
                if (pageYOffset >= targetPoint - 180) {
                    activeId = zone.getAttribute('id');
                }
            });

            targetLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href').includes(activeId)) {
                    link.add('active');
                }
            });
        });

        // Initialize display configuration on loading scripts
        populateStack(structuralTechStack);
    </script>
